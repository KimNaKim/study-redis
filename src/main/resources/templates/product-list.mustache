<!DOCTYPE html>
<html>
<head>
    <title>Redis Sampling Lab - Phase 3</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .status-terminal { background: #1e1e1e; color: #00d000; padding: 15px; border-radius: 8px; font-family: 'Consolas', monospace; height: 300px; overflow-y: auto; margin-top: 20px; border: 2px solid #333; }
        .progress { height: 6px; display: none; margin-bottom: 12px; }
        .source-badge { font-weight: bold; padding: 3px 10px; border-radius: 6px; font-size: 0.8rem; }
        .hit { background-color: #d1e7dd; color: #0f5132; }
        .hit-hash { background-color: #cfe2ff; color: #084298; }
        .miss { background-color: #fff3cd; color: #856404; }
        .benchmark-table { font-size: 0.85rem; background: white; }
        .phase-header { border-left: 5px solid #0d6efd; padding-left: 10px; margin: 20px 0 15px 0; color: #333; }
        .flash-update { animation: flash 1.5s; }
        @keyframes flash { 0% { background-color: #fff3cd; } 100% { background-color: transparent; } }
        .card-custom { border-radius: 12px; border: none; transition: 0.3s; }
        .card-custom:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .recent-item { border-left: 3px solid #dee2e6; transition: 0.2s; cursor: pointer; }
        .recent-item:hover { border-left-color: #0d6efd; background-color: #f8f9fa; }
        .like-btn { cursor: pointer; transition: 0.2s; }
        .like-btn:hover { transform: scale(1.2); }
        .liked { color: #dc3545 !important; }
        /* Phase 5: Notification Styles */
        #notification-container { position: fixed; top: 20px; right: 20px; z-index: 9999; width: 350px; }
        .alert-custom { border-radius: 10px; border: none; box-shadow: 0 5px 15px rgba(0,0,0,0.2); animation: slideIn 0.5s ease-out; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    </style>
</head>
<body class="bg-light">

<!-- Phase 5: Notification Container -->
<div id="notification-container"></div>
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Redis Sampling Lab</h2>
        <div class="d-flex align-items-center">
            {{#isRedisUp}}
            <span class="badge bg-success me-3 py-2 px-3 shadow-sm">
                <i class="bi bi-hdd-network-fill me-1"></i> Redis: <strong>{{redisStatus}}</strong>
            </span>
            {{/isRedisUp}}
            {{^isRedisUp}}
            <span class="badge bg-danger me-3 py-2 px-3 shadow-sm">
                <i class="bi bi-hdd-network me-1"></i> Redis: <strong>{{redisStatus}}</strong>
            </span>
            {{/isRedisUp}}
            <span class="badge bg-white text-dark border me-3 py-2 px-3 shadow-sm">
                <i class="bi bi-people-fill text-primary me-1"></i> Today Visitors: <strong class="text-primary">{{visitorCount}}</strong>
            </span>
            <button class="btn btn-dark" onclick="runBenchmark(1)"><i class="bi bi-lightning-fill text-warning me-1"></i>Performance Test</button>
            <a href="/" class="btn btn-outline-secondary ms-2">Refresh</a>
        </div>
    </div>
    
    <div class="row">
        <div class="col-lg-8">
            <h5 class="phase-header fw-bold text-secondary">Phase 1, 2 & 3: Product Management & Collections</h5>
            <div class="card card-custom shadow-sm p-3 mb-4 bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>ID</th><th>Product Info</th><th>Price Edit</th><th>Stock</th><th class="text-center">Like</th><th class="text-center">Strategy</th></tr>
                    </thead>
                    <tbody>
                        {{#products}}
                        <tr id="row-{{id}}">
                            <td class="fw-bold">{{id}}</td>
                            <td>
                                <div class="fw-bold">{{name}}</div>
                                <small class="text-muted">JPA Resource</small>
                            </td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" id="input-price-{{id}}" value="{{price}}" style="width: 70px;">
                                    <button class="btn btn-outline-warning" onclick="updatePrice({{id}})" title="HSET"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border fw-bold" id="stock-val-{{id}}">{{stock}}</span>
                                <button class="btn btn-sm btn-link text-danger p-0 ms-1" onclick="decreaseStock({{id}})" title="HINCRBY"><i class="bi bi-cart-plus-fill fs-5"></i></button>
                            </td>
                            <td class="text-center">
                                <span class="like-btn fs-5 {{#isLiked}}liked{{/isLiked}}" id="like-btn-{{id}}" onclick="toggleLike({{id}})">
                                    <i class="bi {{#isLiked}}bi-heart-fill{{/isLiked}}{{^isLiked}}bi-heart{{/isLiked}}"></i>
                                </span>
                                <div class="small text-muted" id="like-count-{{id}}">{{likeCount}}</div>
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-primary" onclick="fetchDetail({{id}}, 'hash')">Fetch Detail</button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="clearCache({{id}}, 'hash')" title="Clear"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                        {{/products}}
                    </tbody>
                </table>
            </div>

            <div id="benchmark-result" class="card card-custom shadow-sm mt-4 border-top border-warning border-4" style="display: none;">
                <div class="card-header bg-white fw-bold"><i class="bi bi-graph-up me-2"></i>Comparison Result (1,000 Iterations)</div>
                <div class="card-body p-0">
                    <table class="table benchmark-table align-middle mb-0">
                        <thead class="bg-light">
                            <tr><th>Metric</th><th>Strings (Full Object)</th><th>Hashes (Partial)</th><th>Analysis</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Execution Time</td>
                                <td id="res-s-time" class="text-danger"></td>
                                <td id="res-h-time" class="text-success"></td>
                                <td id="res-t-diff" class="fw-bold text-primary"></td>
                            </tr>
                            <tr>
                                <td>Memory Usage</td>
                                <td id="res-s-mem"></td>
                                <td id="res-h-mem"></td>
                                <td id="res-m-diff" class="text-success"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Phase 3: Recent Products (Lists) -->
            <h5 class="phase-header fw-bold text-secondary">Recent Viewed (Lists)</h5>
            <div class="card card-custom shadow-sm mb-4 bg-white p-2" id="recent-products-list">
                {{#recentProducts}}
                <div class="recent-item p-2 mb-1 rounded" onclick="fetchDetail({{id}}, 'hash')">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold small">{{name}}</span>
                        <span class="badge bg-light text-primary border">$ {{price}}</span>
                    </div>
                </div>
                {{/recentProducts}}
                {{^recentProducts}}
                <div class="text-center py-3 text-muted small">No recently viewed items</div>
                {{/recentProducts}}
            </div>

            <!-- Phase 4: Popular Ranking (Sorted Sets) -->
            <h5 class="phase-header fw-bold text-secondary">Real-time Top 5 (ZSets)</h5>
            <div class="card card-custom shadow-sm mb-4 bg-white p-2" id="ranking-list">
                {{#ranking}}
                <div class="d-flex align-items-center p-2 mb-1 rounded border-bottom-dashed">
                    <span class="badge bg-warning text-dark me-2"># {{score}} Views</span>
                    <span class="fw-bold small text-truncate" style="max-width: 150px;">{{product.name}}</span>
                </div>
                {{/ranking}}
                {{^ranking}}
                <div class="text-center py-3 text-muted small">No rankings available</div>
                {{/ranking}}
            </div>

            <h5 class="phase-header fw-bold text-secondary">Real-time Inspection</h5>
            <div id="detail-card" class="card card-custom shadow-sm mb-3 bg-white" style="display: none;">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h5 class="card-title fw-bold" id="p-name"></h5>
                        <span id="p-source" class="source-badge"></span>
                    </div>
                    <p class="card-text text-muted small" id="p-desc"></p>
                    <div class="row text-center bg-light rounded py-2 m-0">
                        <div class="col-6 border-end">
                            <small class="text-muted d-block">Price</small>
                            <span class="fw-bold text-primary" id="p-price"></span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Stock</small>
                            <span class="fw-bold" id="p-stock"></span>
                        </div>
                    </div>
                    <hr class="my-3">
                    <div id="loading-bar" class="progress"><div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div></div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">Latent Time</span>
                        <span id="p-time" class="fw-bold"></span>
                    </div>
                </div>
            </div>

            <div class="status-terminal shadow-lg" id="terminal">
                <div>> Phase 3: Lists & Sets Ready.</div>
                <div class="text-secondary small">> Try clicking products or heart icons.</div>
            </div>
        </div>
    </div>
</div>

<script>
    function log(msg, color = '#00d000') {
        const term = document.getElementById('terminal');
        const timestamp = new Date().toLocaleTimeString([], { hour12: false });
        term.innerHTML += `<div><small style="color: #666">[${timestamp}]</small> <span style="color: ${color}">> ${msg}</span></div>`;
        term.scrollTop = term.scrollHeight;
    }

    async function fetchDetail(id, type) {
        const detailCard = document.getElementById('detail-card');
        const loadingBar = document.getElementById('loading-bar');
        detailCard.style.display = 'block';
        loadingBar.style.display = 'block';
        
        const endpoint = type === 'hash' ? `/api/products/hash/${id}` : `/api/products/${id}`;
        log(`Checking ${type.toUpperCase()} Cache for ID: ${id}...`, '#3498db');

        try {
            const response = await fetch(endpoint);
            const result = await response.json();
            
            loadingBar.style.display = 'none';
            document.getElementById('p-name').innerText = result.data.name;
            document.getElementById('p-desc').innerText = result.data.description;
            document.getElementById('p-price').innerText = `$ ${result.data.price}`;
            document.getElementById('p-stock').innerText = result.data.stock;
            
            const sourceEl = document.getElementById('p-source');
            sourceEl.innerText = result.source;
            sourceEl.className = 'source-badge ' + (result.source.includes('CACHE') ? (type === 'hash' ? 'hit-hash' : 'hit') : 'miss');
            document.getElementById('p-time').innerText = `${result.elapsedMillis} ms`;

            log(`${result.source} HIT! Added to Recently Viewed (Lists).`, result.source.includes('CACHE') ? '#2ecc71' : '#f1c40f');
            
            // [Phase 3] 사이드바 목록 실시간 갱신
            updateRecentSidebar();
            // [Phase 4] 실시간 랭킹 갱신
            updateRanking();
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    /**
     * [Phase 4] 실시간 인기 랭킹 업데이트 (AJAX)
     */
    async function updateRanking() {
        try {
            const response = await fetch('/api/products/ranking');
            const ranking = await response.json();
            const rankingContainer = document.getElementById('ranking-list');
            
            if (ranking.length === 0) {
                rankingContainer.innerHTML = '<div class="text-center py-3 text-muted small">No rankings available</div>';
                return;
            }

            let html = '';
            ranking.forEach((item, index) => {
                const badgeClass = index === 0 ? 'bg-danger' : (index === 1 ? 'bg-warning text-dark' : 'bg-secondary');
                html += `
                    <div class="d-flex align-items-center p-2 mb-1 rounded border-bottom">
                        <span class="badge ${badgeClass} me-2" style="width: 30px;">${index + 1}</span>
                        <span class="fw-bold small text-truncate flex-grow-1">${item.product.name}</span>
                        <small class="text-muted"><i class="bi bi-eye me-1"></i>${item.score}</small>
                    </div>`;
            });
            rankingContainer.innerHTML = html;
        } catch (err) { console.error('Failed to update ranking:', err); }
    }

    /**
     * [Phase 3] 최근 본 상품 사이드바 실시간 업데이트 (AJAX)
     */
    async function updateRecentSidebar() {
        try {
            const response = await fetch('/api/products/recent');
            const recentProducts = await response.json();
            const listContainer = document.getElementById('recent-products-list');
            
            if (recentProducts.length === 0) {
                listContainer.innerHTML = '<div class="text-center py-3 text-muted small">No recently viewed items</div>';
                return;
            }

            let html = '';
            recentProducts.forEach(p => {
                html += `
                    <div class="recent-item p-2 mb-1 rounded" onclick="fetchDetail(${p.id}, 'hash')">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold small">${p.name}</span>
                            <span class="badge bg-light text-primary border">$ ${p.price}</span>
                        </div>
                    </div>`;
            });
            listContainer.innerHTML = html;
        } catch (err) { console.error('Failed to update sidebar:', err); }
    }

    async function toggleLike(id) {
        const btn = document.getElementById(`like-btn-${id}`);
        const countEl = document.getElementById(`like-count-${id}`);
        const isLiked = btn.classList.contains('liked');
        
        log(`Triggering SADD/SREM for Likes...`, '#e84393');
        try {
            await fetch(`/api/products/${id}/like`, { method: 'POST' });
            
            // UI 실시간 업데이트 (AJAX 방식)
            btn.classList.toggle('liked');
            const icon = btn.querySelector('i');
            icon.classList.toggle('bi-heart');
            icon.classList.toggle('bi-heart-fill');
            
            let currentCount = parseInt(countEl.innerText);
            countEl.innerText = isLiked ? currentCount - 1 : currentCount + 1;
            
            log(`${isLiked ? 'Removed' : 'Added'} Like successfully. (Sets)`, '#2ecc71');
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    async function updatePrice(id) {
        const newPrice = document.getElementById(`input-price-${id}`).value;
        const row = document.getElementById(`row-${id}`);
        log(`Triggering HSET for field [price]...`, '#f39c12');
        
        try {
            await fetch(`/api/products/${id}/price?price=${newPrice}`, { method: 'PATCH' });
            row.classList.add('flash-update');
            setTimeout(() => row.classList.remove('flash-update'), 1500);
            log(`Success: Partial update complete.`, '#2ecc71');
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    async function decreaseStock(id) {
        log(`Triggering Atomic HINCRBY (stock, -1)...`, '#f39c12');
        try {
            await fetch(`/api/products/${id}/decrease-stock?quantity=1`, { method: 'POST' });
            log(`Success: 원자적 재고 차감 완료.`, '#2ecc71');
            fetchDetail(id, 'hash');
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    async function clearCache(id, type) {
        log(`Purging ${type.toUpperCase()} cache from Redis...`, '#e74c3c');
        try {
            await fetch(`/api/products/${id}/cache?type=${type}`, { method: 'DELETE' });
            log(`Success: Cache cleared.`, '#bdc3c7');
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    async function runBenchmark(id) {
        log(`<strong>Starting 1,000 Iterations Benchmark...</strong>`, '#fff');
        document.getElementById('benchmark-result').style.display = 'none';

        try {
            const response = await fetch(`/api/benchmark/${id}`);
            const result = await response.json();
            
            document.getElementById('benchmark-result').style.display = 'block';
            document.getElementById('res-s-time').innerText = `${result.stringsTimeMillis} ms`;
            document.getElementById('res-h-time').innerText = `${result.hashesTimeMillis} ms`;
            
            const timeDiff = (result.stringsTimeMillis / (result.hashesTimeMillis || 1)).toFixed(1);
            document.getElementById('res-t-diff').innerText = `🚀 ${timeDiff}x Faster`;

            document.getElementById('res-s-mem').innerText = `${result.stringsMemoryBytes} B`;
            document.getElementById('res-h-mem').innerText = `${result.hashesMemoryBytes} B`;
            document.getElementById('res-m-diff').innerText = `📉 ${result.stringsMemoryBytes - result.hashesMemoryBytes} B Saved`;

            log(`Benchmark Complete!`, '#9b59b6');
        } catch (err) { log(`Error: ${err.message}`, '#e74c3c'); }
    }

    /**
     * [Phase 5] 실시간 알림 구독 (SSE)
     */
    function subscribeToNotifications() {
        const eventSource = new EventSource('/api/notifications/subscribe');
        
        eventSource.addEventListener('INIT', (e) => {
            log(`SSE Notification Service: ${e.data}`, '#9b59b6');
        });

        eventSource.addEventListener('inventory-alert', (e) => {
            const message = e.data;
            log(`Real-time Alert Received: ${message}`, '#e67e22');
            showNotification(message);
        });

        eventSource.onerror = (err) => {
            console.error('SSE connection failed:', err);
            eventSource.close();
        };
    }

    function showNotification(message) {
        const container = document.getElementById('notification-container');
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-warning alert-dismissible fade show alert-custom mb-2';
        alertDiv.innerHTML = `
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Alert!</strong> ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;
        container.appendChild(alertDiv);

        // 5초 후 자동 삭제
        setTimeout(() => {
            alertDiv.classList.remove('show');
            setTimeout(() => alertDiv.remove(), 500);
        }, 5000);
    }

    // 페이지 로드 시 알림 구독 시작
    window.onload = () => {
        subscribeToNotifications();
        // 5초마다 랭킹 자동 갱신
        setInterval(updateRanking, 5000);
    };
</script>
</body>
</html>
